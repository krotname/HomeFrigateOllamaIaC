services:
  frigate:
    container_name: frigate
    image: {{ frigate_image }}
    restart: unless-stopped
    stop_grace_period: 30s
    shm_size: "512mb"
    env_file:
      - .env
    environment:
      TZ: {{ frigate_timezone }}
      NVIDIA_VISIBLE_DEVICES: all
      NVIDIA_DRIVER_CAPABILITIES: compute,video,utility
    extra_hosts:
      - "host.docker.internal:host-gateway"
    runtime: nvidia
    deploy:
      resources:
        reservations:
          devices:
            - driver: nvidia
              count: 1
              capabilities: [gpu]
    volumes:
      - /etc/localtime:/etc/localtime:ro
      - ./config:/config
      - ./certs:/etc/letsencrypt/live/frigate:ro
      - {{ frigate_media_path }}:/media/frigate
      - type: tmpfs
        target: /tmp/cache
        tmpfs:
          size: 1000000000
    ports:
      - "127.0.0.1:{{ frigate_vm_frigate_backend_port_resolved }}:8971"
      - "{{ frigate_vm_ip }}:8554:8554"
      - "{{ frigate_vm_ip }}:8555:8555/tcp"
      - "{{ frigate_vm_ip }}:8555:8555/udp"
    logging:
      driver: json-file
      options:
        max-size: "20m"
        max-file: "5"
